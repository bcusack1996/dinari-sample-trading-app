# Dinari sandbox credentials (https://partners.dinari.com)
# Base URL is selected in code via `environment: "sandbox"`; do not set DINARI_BASE_URL.
DINARI_API_KEY_ID=
DINARI_API_SECRET_KEY=

# thirdweb credentials (https://thirdweb.com/dashboard)
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
# 32-byte hex string used to sign auth JWTs. Generate with:
#   openssl rand -hex 32
THIRDWEB_AUTH_PRIVATE_KEY=

# Public app URL (used as the SIWE domain/origin during auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SQLite database file
DATABASE_URL="file:./dev.db"
